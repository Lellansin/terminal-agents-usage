{
  "name": "terminal-agents-usage",
  "version": "0.0.4",
  "description": "Unified usage dashboard for terminal AI coding agents (Claude Code, Codex, OpenClaw, etc.)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "terminal-agents-usage": "dist/index.js",
    "usage": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "scan": "tsx src/index.ts scan",
    "dashboard": "tsx src/index.ts dashboard",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "claude",
    "codex",
    "openclaw",
    "ai",
    "usage",
    "dashboard"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/react": "^19.2.14",
    "better-sqlite3": "^11.7.0",
    "chart.js": "^4.4.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "ink": "^7.0.3",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
